# ============================================
# NIFTY Trading Terminal - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys

# Twelve Data API Key (FREE: 800 credits/day)
# Get at: https://twelvedata.com/register
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Alpha Vantage API Key (FREE: 25 requests/day)
# Get at: https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub API Key (FREE: 60 calls/minute)
# Get at: https://finnhub.io/register
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Claude AI API Key (for AI Predictions page)
# Get at: https://console.anthropic.com
# Free tier: $5 credit on signup (~500 analysis calls with Haiku)
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here

# App Settings
VITE_REFRESH_INTERVAL=30000
VITE_USE_MOCK_DATA=true

# ── Groww Trading API (server-side only — NO VITE_ prefix) ──
# Subscribe: https://groww.in/user/profile/trading-apis  | Keys: https://groww.in/trade-api/api-keys
# Approval flow: paste API key + secret. (TOTP secret optional, for hands-off auth.)
GROWW_API_KEY=your_groww_api_key_here
GROWW_API_SECRET=your_groww_api_secret_here
GROWW_TOTP_SECRET=
